# Belvo (conectividade bancária)
# Use aspas duplas na senha se contiver # ou outros caracteres especiais
BELVO_SECRET_KEY=
BELVO_SECRET_PASSWORD=
BELVO_ENV=sandbox
# Opcional: URL do widget (padrão: https://widget.belvo.io)
# NEXT_PUBLIC_BELVO_WIDGET_URL=

# Supabase (banco de dados)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Obrigatório para área admin (listar usuários, entrar como cliente)
SUPABASE_SERVICE_ROLE_KEY=

# Admin (login: admin@mail.com)
# Para criar o usuário admin uma vez: POST /api/admin/seed com body { "secret": "<ADMIN_SEED_SECRET>" }
ADMIN_SEED_SECRET=
# Senha inicial do admin (padrão: mariagb123)
# ADMIN_INITIAL_PASSWORD=mariagb123

# Stripe (plano Pro)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
STRIPE_PRO_PRICE_ID=
